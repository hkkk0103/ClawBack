# ShillTracer backend env
# Fill in your own keys before deployment.

# Required: one or more Moralis keys, comma-separated for rotation
MORALIS_API_KEYS=your_moralis_key_1,your_moralis_key_2

# Optional fallback for Mode A / block lookup helpers
BSCSCAN_API_KEY=your_bscscan_api_key

# Optional runtime port
PORT=5001
